:root {
  --lc-accent: #ff5e00;
  --lc-pink: #ff61a6;
  --_font-family---title-font: Raleway, sans-serif;
  --_font-family---text-font: Raleway, sans-serif;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: Raleway, sans-serif;
  text-rendering: geometricPrecision;
  -webkit-font-smoothing: antialiased;
}

body :where(h1, h2, h3, h4, h5, h6, p, a, span, div, button, input, textarea, select, label) {
  font-family: Raleway, sans-serif;
}

[class^="w-icon-"],
[class*=" w-icon-"],
.social-icon {
  font-family: webflow-icons, Arial, sans-serif !important;
}

:where(a, button, input, textarea, select):focus-visible {
  outline: 2px solid rgba(255, 94, 0, 0.85);
  outline-offset: 3px;
}

.page-wrapper {
  overflow: clip;
}

img {
  max-width: 100%;
}

.bg.hero-bg {
  background-image: url("../assets/portfolio/main-img.jpg") !important;
}

.bg.start-your-brand-bg,
.bg.project-info-bg {
  background-image: url("../assets/portfolio/start-your-brand.jpg") !important;
}

.contact-input,
.contact-button,
.theme-button,
.footer-list-link,
.social-icon-link,
.pricing-single,
.project-single,
.service-single,
.process-single,
.brands-gallery-card {
  -webkit-tap-highlight-color: transparent;
}

.contact-input {
  transition: border-color 220ms cubic-bezier(0.16, 1, 0.3, 1),
    box-shadow 220ms cubic-bezier(0.16, 1, 0.3, 1),
    background-color 220ms cubic-bezier(0.16, 1, 0.3, 1);
}

.contact-input:focus {
  border-color: rgba(255, 94, 0, 0.65);
  box-shadow: 0 0 0 4px rgba(255, 94, 0, 0.16);
}

.contact-button,
.theme-button,
.pricing-single,
.project-single,
.service-single,
.process-single,
.brands-gallery-card {
  transition: transform 420ms cubic-bezier(0.16, 1, 0.3, 1),
    box-shadow 420ms cubic-bezier(0.16, 1, 0.3, 1),
    filter 420ms cubic-bezier(0.16, 1, 0.3, 1);
}

.theme-btn-icon-box {
  background: #000 !important;
  border-radius: 999px;
}

.theme-button .theme-btn-bg {
  background: #000 !important;
}

@media (hover: hover) {
  .pricing-single:hover,
  .project-single:hover,
  .service-single:hover,
  .process-single:hover,
  .brands-gallery-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
  }

  .contact-button:hover,
  .theme-button:hover {
    transform: translateY(-1px);
    filter: saturate(1.05) contrast(1.02);
  }
}

.w-form-done,
.w-form-fail {
  border-radius: 20px;
}

.ai-note-section {
  padding-top: clamp(64px, 8vw, 120px);
}

.brands-gallery-card img,
.project-detail-image,
.case-image-full,
.case-image-grid img,
.gallery-image,
.project-image,
.marquee-image,
.process-image {
  background: #181818;
}

.project-video {
  display: block;
  object-fit: cover;
  width: 100%;
  height: 100%;
}

.social-icon {
  font-family: Arial, sans-serif !important;
  font-size: 0 !important;
}

.social-icon::before {
  content: "";
  display: block;
  width: 18px;
  height: 18px;
  border-radius: 999px;
  background: var(--lc-accent);
  box-shadow: inset 0 0 0 5px rgba(255, 255, 255, 0.18);
}

@media (max-width: 991px) {
  .container {
    width: min(100% - 32px, 100%);
  }

  .hero-title,
  .project-info-title,
  .section-title {
    word-break: normal;
    overflow-wrap: normal;
  }
}

@media (max-width: 767px) {
  .banner-list-box {
    gap: 16px;
  }

  .contact-form-grid,
  .footer-grid,
  .case-study-header,
  .case-image-grid {
    grid-template-columns: 1fr !important;
  }

  .brands-gallery-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }
}

@media (max-width: 479px) {
  .container {
    width: min(100% - 24px, 100%);
  }

  .brands-gallery-grid {
    gap: 8px !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.01ms !important;
  }
}

/* Final hero lock: title and descriptor share the same left edge. */
.hero-content-box {
  display: block !important;
  width: 100% !important;
  margin-bottom: clamp(22px, 4.6vh, 64px) !important;
}

.hero-left-box {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-start !important;
  width: min(100%, 1180px) !important;
  gap: clamp(16px, 2.2vw, 32px) !important;
}

.hero-title-outer,
.hero-title-box,
.hero-title-box.two {
  position: relative !important;
  width: fit-content !important;
  max-width: 100% !important;
  height: auto !important;
  align-self: flex-start !important;
  justify-self: start !important;
  margin-left: 0 !important;
  left: 0 !important;
}

.hero-title-box.one {
  display: none !important;
}

.hero-title-box.two {
  overflow: hidden !important;
  padding: 0.12em 0.08em 0.16em 0 !important;
  margin: -0.12em -0.08em -0.16em 0 !important;
  clip-path: inset(0 100% 0 0);
  animation: heroTitleReveal 950ms cubic-bezier(0.16, 1, 0.3, 1) 180ms forwards;
}

.hero-title {
  font-size: clamp(76px, 11.2vw, 214px) !important;
  font-weight: 600 !important;
  line-height: 0.92 !important;
  letter-spacing: -0.075em !important;
  margin: 0 !important;
  white-space: nowrap !important;
}

.hero-text-box {
  width: min(100%, 520px) !important;
  margin: 0 !important;
  padding-left: 0 !important;
  align-self: flex-start !important;
  justify-self: start !important;
  text-align: left !important;
  overflow: hidden !important;
  clip-path: inset(0 100% 0 0);
  animation: heroTitleReveal 900ms cubic-bezier(0.16, 1, 0.3, 1) 360ms forwards;
}

.hero-title-two {
  font-size: clamp(18px, 1.5vw, 30px) !important;
  font-weight: 600 !important;
  line-height: 1.14 !important;
  letter-spacing: -0.03em !important;
  text-align: left !important;
  margin: 0 !important;
}

@keyframes heroTitleReveal {
  to {
    clip-path: inset(0 0 0 0);
  }
}

@media (min-width: 1920px) {
  .hero-left-box {
    width: min(100%, 1320px) !important;
  }

  .hero-title {
    font-size: clamp(190px, 10.4vw, 224px) !important;
  }
}

@media (max-width: 1279px) {
  .hero-title {
    font-size: clamp(72px, 12vw, 138px) !important;
  }
}

@media (max-width: 767px) {
  .hero-left-box {
    gap: 18px !important;
  }

  .hero-title {
    font-size: clamp(52px, 17vw, 92px) !important;
    line-height: 0.96 !important;
  }

  .hero-title-two {
    font-size: clamp(18px, 5vw, 24px) !important;
  }
}

@media (max-width: 479px) {
  .hero-title {
    font-size: clamp(44px, 16.5vw, 66px) !important;
    letter-spacing: -0.045em !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-title-box.two,
  .hero-text-box {
    clip-path: inset(0 0 0 0) !important;
    animation: none !important;
  }

  .hero-text-box {
    opacity: 1 !important;
  }

  .banner-list {
    opacity: 1 !important;
    transform: none !important;
    animation: none !important;
  }
}

/* Absolute final hero fix: no clipped last letter, descriptor always below title. */
.hero-content-box {
  display: block !important;
  width: 100% !important;
}

.hero-left-box {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-start !important;
  justify-content: flex-end !important;
  width: min(100%, 1320px) !important;
  max-width: 100% !important;
  gap: clamp(16px, 2.2vw, 32px) !important;
}

.hero-title-outer {
  order: 1 !important;
  display: block !important;
  width: max-content !important;
  max-width: none !important;
  overflow: visible !important;
}

.hero-title-box,
.hero-title-box.two {
  display: block !important;
  width: max-content !important;
  min-width: max-content !important;
  max-width: none !important;
  height: auto !important;
  position: relative !important;
}

.hero-title-box.one {
  display: none !important;
}

.hero-title-box.two {
  overflow: hidden !important;
  padding: 0.16em 0.36em 0.2em 0 !important;
  margin: -0.16em -0.36em -0.2em 0 !important;
  clip-path: inset(-0.12em 100% -0.16em 0);
  animation: heroTitleRevealSafe 2000ms cubic-bezier(0.19, 1, 0.22, 1) 180ms forwards !important;
}

.hero-title {
  display: block !important;
  width: max-content !important;
  max-width: none !important;
  font-weight: 600 !important;
  white-space: nowrap !important;
}

.hero-text-box {
  order: 2 !important;
  width: min(100%, 560px) !important;
  margin: 0 !important;
  padding: 0 !important;
  align-self: flex-start !important;
  justify-self: start !important;
  overflow: visible !important;
  clip-path: none !important;
  opacity: 0;
  animation: heroDescriptorFade 1000ms cubic-bezier(0.19, 1, 0.22, 1) 1180ms forwards !important;
}

.hero-title-two {
  text-align: left !important;
  margin: 0 !important;
}

@keyframes heroTitleRevealSafe {
  to {
    clip-path: inset(-0.12em -0.36em -0.16em 0);
  }
}

@media (max-width: 767px) {
  .hero-left-box {
    gap: 18px !important;
  }

  .hero-title-outer,
  .hero-title-box,
  .hero-title-box.two,
  .hero-title {
    max-width: none !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-title-box.two {
    clip-path: inset(-0.12em -0.36em -0.16em 0) !important;
    animation: none !important;
  }

  .hero-text-box {
    opacity: 1 !important;
    animation: none !important;
  }
}

/* Absolute final hero fix: no clipped last letter, descriptor always below title. */
.hero-content-box {
  display: block !important;
  width: 100% !important;
}

.hero-left-box {
