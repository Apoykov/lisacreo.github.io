  }

  .hero-title-outer,
  .hero-title-box,
  .hero-title-box.two,
  .hero-title {
    max-width: none !important;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-title-box.two {
    clip-path: inset(-0.12em -0.36em -0.16em 0) !important;
    animation: none !important;
  }

  .hero-text-box {
    opacity: 1 !important;
    animation: none !important;
  }
}

/* Hero animation correction: safe title mask, descriptor fades without mask. */
.hero-title-box.two {
  overflow: hidden !important;
  padding: 0.14em 0.24em 0.18em 0 !important;
  margin: -0.14em -0.24em -0.18em 0 !important;
  clip-path: inset(-0.08em 100% -0.12em 0);
  animation: heroTitleRevealWebflow 2000ms cubic-bezier(0.19, 1, 0.22, 1) 180ms forwards !important;
}

.hero-text-box {
  overflow: visible !important;
  clip-path: none !important;
  opacity: 0;
  animation: heroDescriptorFade 1000ms cubic-bezier(0.19, 1, 0.22, 1) 1180ms forwards !important;
}

@keyframes heroTitleRevealWebflow {
  to {
    clip-path: inset(-0.08em -0.24em -0.12em 0);
  }
}

@keyframes heroDescriptorFade {
  to {
    opacity: 1;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-title-box.two {
    clip-path: inset(-0.08em -0.24em -0.12em 0) !important;
    animation: none !important;
  }

  .hero-text-box {
    opacity: 1 !important;
    animation: none !important;
  }
}

/* Final hero composition: title above descriptor with a safe reveal mask. */
.hero-content-box {
  display: block !important;
  width: 100%;
  margin-bottom: clamp(22px, 4.6vh, 64px) !important;
}

.hero-left-box {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: min(100%, 1180px);
  gap: clamp(16px, 2.2vw, 32px);
}

.hero-title-outer,
.hero-title-box,
.hero-title-box.two {
  position: relative !important;
  width: fit-content !important;
  max-width: 100% !important;
  height: auto !important;
}

.hero-title-box.one {
  display: none !important;
}

.hero-title-box.two {
  overflow: hidden !important;
  padding: 0.12em 0.08em 0.16em 0;
  margin: -0.12em -0.08em -0.16em 0;
  clip-path: inset(0 100% 0 0);
  animation: heroTitleReveal 950ms cubic-bezier(0.16, 1, 0.3, 1) 180ms forwards;
}

.hero-title {
  font-size: clamp(76px, 11.2vw, 214px) !important;
  font-weight: 600 !important;
  line-height: 0.92 !important;
  letter-spacing: -0.075em !important;
  margin: 0 !important;
  white-space: nowrap;
}

.hero-text-box {
  width: min(100%, 520px) !important;
  margin: 0 !important;
  overflow: hidden;
  clip-path: inset(0 100% 0 0);
  animation: heroTitleReveal 900ms cubic-bezier(0.16, 1, 0.3, 1) 360ms forwards;
}

.hero-title-two {
  font-size: clamp(18px, 1.5vw, 30px) !important;
  font-weight: 600 !important;
  line-height: 1.14 !important;
  letter-spacing: -0.03em;
  text-align: left !important;
  margin: 0 !important;
}

@keyframes heroTitleReveal {
  to {
    clip-path: inset(0 0 0 0);
  }
}

@media (min-width: 1920px) {
  .hero-left-box {
    width: min(100%, 1320px);
  }

  .hero-title {
    font-size: clamp(190px, 10.4vw, 224px) !important;
  }
}

@media (max-width: 1279px) {
  .hero-title {
    font-size: clamp(72px, 12vw, 138px) !important;
  }
}

@media (max-width: 767px) {
  .hero-left-box {
    gap: 18px;
  }

  .hero-title {
    font-size: clamp(52px, 17vw, 92px) !important;
    line-height: 0.96 !important;
  }

